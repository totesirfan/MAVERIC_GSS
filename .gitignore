# === Python ===
__pycache__/
*.pyc
*.pyo
.pytest_cache/
# Updater-managed venv bootstrap target (PEP 668 fallback)
.venv/
# Updater requirements.txt install marker (sha256 of last successful install)
.mav_requirements_hash
# Developer opt-out — touch .mav_dev at repo root to disable the self-updater
.mav_dev

# === Node (dependency state only — dist/ is committed) ===
node_modules/
mav_gss_lib/web/node_modules/

# === Logs & Runtime Outputs ===
/logs/
/images/
tests/test_images/
tests/images/
backup_control/logs/
generated_commands/
.pending_queue.jsonl
# GNC register-snapshot sidecar (persisted latest-value-per-register cache)
.gnc_snapshot.json

# === Mission-Sensitive (NEVER track) ===
# Command schema contains mission command definitions — security sensitive
mav_gss_lib/missions/maveric/commands.yml
# Local mission config overrides — operator-specific, may contain sensitive params
mav_gss_lib/missions/*/mission.yml
!mav_gss_lib/missions/*/mission.example.yml

# === Operator-Local Config ===
# Main station config — operator ZMQ addresses, local paths
mav_gss_lib/gss.yml
