.gnc_snapshot.json

# === Mission-Sensitive (NEVER track) ===
# Command schema contains mission command definitions — security sensitive
mav_gss_lib/missions/maveric/commands.yml
# Local mission config overrides — operator-specific, may contain sensitive params
mav_gss_lib/missions/*/mission.yml
!mav_gss_lib/missions/*/mission.example.yml

# === Operator-Local Config ===
# Main station config — operator ZMQ addresses, local paths
mav_gss_lib/gss.yml
